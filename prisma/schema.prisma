generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Travel profile
  travelStatus    String?   // "single", "couple", "family", "group"
  numberOfKids    Int?      // 0 if no kids
  kidsAges        String?   // e.g. "3, 7, 12"
  petFriendly     Boolean?  // travels with pets?
  budgetStyle     String?   // "backpacker", "mid-range", "luxury"
  travelPace      String?   // "slow", "moderate", "packed"
  interests       String?   // comma-separated: "food, history, hiking, art"
  mobilityNeeds   String?   // "none", "limited-walking", "wheelchair"
  dietaryNeeds    String?   // "none", "vegetarian", "vegan", "halal", "kosher"
  profileComplete Boolean   @default(false)

  accounts Account[]
  sessions Session[]
  trips    Trip[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  title     String
  query     String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}